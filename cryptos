  const m = currentMethod;
  const op = currentOp;
  const isSym = m.type === 'sym';
  const colorVar = isSym ? 'var(--cyan)' : 'var(--purple)';
  const opLabel = op === 'encrypt' ? '⚡ Encryption' : op === 'decrypt' ? '🔓 Decryption' : op === 'hash' ? '# Hashing' : '🔑 Key Exchange';

  document.getElementById('op-mode-label').textContent = `${m.name} — ${opLabel}`;
  document.getElementById('op-title').textContent = `${m.name} ${opLabel.replace(/[⚡🔓#🔑]\s*/,'')}`.toUpperCase();
