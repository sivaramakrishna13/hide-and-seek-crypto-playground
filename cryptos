<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hide & Seek — Cryptographic Playground</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #020408;
  --bg2: #040c14;
  --grid: rgba(0,200,255,0.04);
  --cyan: #00e5ff;
  --cyan2: #00b8d4;
  --green: #00ff9d;
  --red: #ff3366;
  --amber: #ffb700;
  --purple: #bb86fc;
  --white: #e0f7ff;
  --dim: rgba(224,247,255,0.4);
  --panel: rgba(0,20,35,0.85);
  --border: rgba(0,229,255,0.18);
  --glow: 0 0 18px rgba(0,229,255,0.45);
  --glow-green: 0 0 18px rgba(0,255,157,0.45);
  --glow-red: 0 0 18px rgba(255,51,102,0.4);
  --glow-purple: 0 0 18px rgba(187,134,252,0.45);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--white);font-family:'Rajdhani',sans-serif;min-height:100vh;overflow-x:hidden;position:relative;}

#bg-canvas{position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;pointer-events:none;opacity:0.35;}
.grid-overlay{position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;background-image:linear-gradient(var(--grid) 1px,transparent 1px),linear-gradient(90deg,var(--grid) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;}
.scanlines{position:fixed;top:0;left:0;width:100%;height:100%;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.03) 2px,rgba(0,0,0,0.03) 4px);pointer-events:none;z-index:5;}
.corner-deco{position:fixed;width:50px;height:50px;pointer-events:none;z-index:6;opacity:0.4;}
.corner-deco.tl{top:12px;left:12px;border-top:2px solid var(--cyan);border-left:2px solid var(--cyan);}
.corner-deco.tr{top:12px;right:12px;border-top:2px solid var(--cyan);border-right:2px solid var(--cyan);}
.corner-deco.bl{bottom:12px;left:12px;border-bottom:2px solid var(--cyan);border-left:2px solid var(--cyan);}
.corner-deco.br{bottom:12px;right:12px;border-bottom:2px solid var(--cyan);border-right:2px solid var(--cyan);}

.page{display:none;position:relative;z-index:10;min-height:100vh;}
.page.active{display:flex;flex-direction:column;}

/* ═══ LOGO ═══ */
.logo{font-family:'Orbitron',monospace;font-size:clamp(1.4rem,4vw,2.6rem);font-weight:900;letter-spacing:0.12em;color:var(--cyan);text-shadow:var(--glow),0 0 60px rgba(0,229,255,0.25);animation:pulse-logo 3s ease-in-out infinite;}
@keyframes pulse-logo{0%,100%{text-shadow:var(--glow),0 0 60px rgba(0,229,255,0.25);}50%{text-shadow:0 0 25px rgba(0,229,255,0.9),0 0 80px rgba(0,229,255,0.4);}}
.logo span{color:var(--green);}
.tagline{font-family:'Share Tech Mono',monospace;font-size:0.72rem;color:var(--dim);letter-spacing:0.3em;margin-top:0.4rem;text-transform:uppercase;}
.header-line{width:100%;height:1px;background:linear-gradient(90deg,transparent,var(--cyan),transparent);margin-top:1.2rem;opacity:0.5;}
.glitch-text{animation:glitch 8s infinite;}
@keyframes glitch{0%,94%,100%{text-shadow:var(--glow);}95%{text-shadow:-2px 0 var(--red),2px 0 var(--green);transform:skewX(-1deg);}96%{text-shadow:2px 0 var(--red),-2px 0 var(--green);transform:skewX(1deg);}97%{text-shadow:var(--glow);transform:none;}}

/* ══════════════════════════════════════════════
   LOGIN PAGE
══════════════════════════════════════════════ */
#login.active{align-items:center;justify-content:center;}
.login-wrapper{width:100%;max-width:440px;padding:2rem 1.5rem;display:flex;flex-direction:column;align-items:center;gap:2rem;}
.login-header{text-align:center;}
.login-icon{font-size:4rem;display:block;margin-bottom:1rem;filter:drop-shadow(0 0 20px var(--cyan));animation:icon-float 3s ease-in-out infinite;}
@keyframes icon-float{0%,100%{transform:translateY(0);}50%{transform:translateY(-10px);}}
.login-box{width:100%;background:var(--panel);border:1px solid var(--border);border-radius:6px;padding:2rem;backdrop-filter:blur(12px);box-shadow:0 0 40px rgba(0,229,255,0.08);}
.login-title{font-family:'Orbitron',monospace;font-size:0.8rem;color:var(--cyan);letter-spacing:0.25em;text-transform:uppercase;margin-bottom:1.8rem;text-align:center;}
.form-group{margin-bottom:1.4rem;}
.form-label{font-family:'Share Tech Mono',monospace;font-size:0.72rem;color:var(--dim);letter-spacing:0.15em;text-transform:uppercase;display:block;margin-bottom:0.5rem;}
.form-input{width:100%;background:rgba(0,15,30,0.9);border:1px solid var(--border);border-radius:3px;color:var(--white);font-family:'Share Tech Mono',monospace;font-size:0.9rem;padding:0.75rem 1rem;transition:border-color 0.2s,box-shadow 0.2s;outline:none;caret-color:var(--cyan);}
.form-input:focus{border-color:var(--cyan2);box-shadow:0 0 12px rgba(0,229,255,0.2);}
.form-input::placeholder{color:rgba(224,247,255,0.2);}
.login-btn{width:100%;padding:0.9rem;background:transparent;border:1px solid var(--cyan);color:var(--cyan);font-family:'Orbitron',monospace;font-size:0.82rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;cursor:pointer;transition:all 0.3s;border-radius:3px;margin-top:0.5rem;position:relative;overflow:hidden;}
.login-btn::before{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(0,229,255,0.12),transparent);transition:left 0.4s;}
.login-btn:hover::before{left:100%;}
.login-btn:hover{background:rgba(0,229,255,0.1);box-shadow:var(--glow);}
.login-hint{font-family:'Share Tech Mono',monospace;font-size:0.65rem;color:rgba(224,247,255,0.2);text-align:center;margin-top:1rem;letter-spacing:0.1em;}
.login-err{font-family:'Share Tech Mono',monospace;font-size:0.72rem;color:var(--red);text-align:center;margin-top:0.8rem;display:none;}

/* ══════════════════════════════════════════════
   HOME PAGE (after login)
══════════════════════════════════════════════ */
#home.active{justify-content:flex-start;align-items:center;}
header{text-align:center;padding:2.2rem 1rem 1rem;position:relative;}
.logout-btn{position:absolute;top:1.5rem;right:1.5rem;font-family:'Share Tech Mono',monospace;font-size:0.7rem;color:var(--dim);background:transparent;border:1px solid var(--border);padding:0.4rem 0.9rem;border-radius:2px;cursor:pointer;letter-spacing:0.1em;transition:all 0.2s;}
.logout-btn:hover{color:var(--red);border-color:var(--red);}

.home-cards{display:flex;gap:2.5rem;padding:3rem 2rem;width:100%;max-width:1100px;margin:0 auto;flex-wrap:wrap;justify-content:center;flex:1;align-items:center;}
.home-card{flex:1 1 400px;max-width:480px;min-height:360px;background:var(--panel);border:1px solid var(--border);border-radius:4px;padding:2.5rem 2rem;cursor:pointer;position:relative;overflow:hidden;transition:all 0.35s cubic-bezier(.4,0,.2,1);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;gap:1.2rem;backdrop-filter:blur(8px);}
.home-card::before{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(0,229,255,0.05),transparent);transition:left 0.5s ease;}
.home-card:hover::before{left:100%;}
.home-card:hover{border-color:var(--cyan);box-shadow:var(--glow),inset 0 0 40px rgba(0,229,255,0.05);transform:translateY(-4px);}
.asym-card:hover{border-color:var(--purple);box-shadow:var(--glow-purple),inset 0 0 40px rgba(187,134,252,0.05);}
.card-icon{font-size:3.5rem;filter:drop-shadow(0 0 12px currentColor);animation:icon-float 4s ease-in-out infinite;}
.sym-card .card-icon{color:var(--cyan);}
.asym-card .card-icon{color:var(--purple);}
.card-title{font-family:'Orbitron',monospace;font-size:0.95rem;font-weight:700;letter-spacing:0.08em;color:var(--white);}
.card-number{font-family:'Orbitron',monospace;font-size:2rem;font-weight:900;opacity:0.15;position:absolute;top:1rem;right:1.2rem;}
.card-desc{font-size:1rem;color:var(--dim);line-height:1.55;font-weight:300;}
.card-methods{display:flex;flex-wrap:wrap;gap:0.4rem;justify-content:center;margin-top:0.5rem;}
.card-method-tag{font-family:'Share Tech Mono',monospace;font-size:0.6rem;padding:2px 8px;border-radius:2px;letter-spacing:0.08em;}
.sym-tag{background:rgba(0,229,255,0.1);color:var(--cyan);border:1px solid rgba(0,229,255,0.25);}
.asym-tag{background:rgba(187,134,252,0.1);color:var(--purple);border:1px solid rgba(187,134,252,0.25);}
.card-btn{margin-top:0.8rem;padding:0.6rem 2rem;border:1px solid currentColor;background:transparent;border-radius:2px;font-family:'Share Tech Mono',monospace;font-size:0.8rem;letter-spacing:0.15em;cursor:pointer;transition:all 0.2s;text-transform:uppercase;}
.sym-card .card-btn{color:var(--cyan);}
.asym-card .card-btn{color:var(--purple);}
.home-card:hover .card-btn{background:rgba(0,229,255,0.1);}
.asym-card:hover .card-btn{background:rgba(187,134,252,0.1);}
.divider-v{width:1px;height:280px;background:linear-gradient(180deg,transparent,var(--border),var(--cyan2),var(--border),transparent);flex-shrink:0;align-self:center;position:relative;}
.divider-v::after{content:'VS';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:'Share Tech Mono',monospace;font-size:0.65rem;color:var(--cyan2);background:var(--bg);padding:4px 6px;letter-spacing:0.2em;}

/* ══════════════════════════════════════════════
   SUB-HOME: METHOD SELECTION PAGE
══════════════════════════════════════════════ */
#method-select.active{justify-content:flex-start;align-items:center;}
.method-select-header{width:100%;max-width:1000px;margin:0 auto;padding:2rem 1.5rem 1rem;}
.ms-mode-toggle{display:flex;gap:1rem;margin-top:1.5rem;justify-content:center;}
.ms-tab{padding:0.6rem 1.6rem;border:1px solid var(--border);background:transparent;font-family:'Share Tech Mono',monospace;font-size:0.78rem;letter-spacing:0.12em;cursor:pointer;transition:all 0.2s;text-transform:uppercase;border-radius:2px;}
.ms-tab.sym-active{border-color:var(--cyan);color:var(--cyan);background:rgba(0,229,255,0.08);}
.ms-tab.asym-active{border-color:var(--purple);color:var(--purple);background:rgba(187,134,252,0.08);}
.ms-tab:not(.sym-active):not(.asym-active){color:var(--dim);}
.ms-ops{display:flex;gap:0.8rem;justify-content:center;margin-top:1rem;}
.ms-op-btn{padding:0.5rem 1.2rem;border:1px solid var(--border);background:transparent;font-family:'Share Tech Mono',monospace;font-size:0.72rem;letter-spacing:0.1em;cursor:pointer;color:var(--dim);transition:all 0.2s;text-transform:uppercase;border-radius:2px;}
.ms-op-btn.active-enc{border-color:var(--cyan);color:var(--cyan);background:rgba(0,229,255,0.07);}
.ms-op-btn.active-dec{border-color:var(--green);color:var(--green);background:rgba(0,255,157,0.07);}
.ms-op-btn.active-hash{border-color:var(--amber);color:var(--amber);background:rgba(255,183,0,0.07);}
.method-select-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1.2rem;padding:1.5rem;width:100%;max-width:1000px;margin:0 auto;}
.ms-card{background:var(--panel);border:1px solid var(--border);border-radius:4px;padding:1.4rem 1.2rem;cursor:pointer;transition:all 0.25s;backdrop-filter:blur(6px);position:relative;overflow:hidden;}
.ms-card::after{content:'→';position:absolute;bottom:0.8rem;right:1rem;font-size:1.2rem;opacity:0;transition:opacity 0.2s,transform 0.2s;transform:translateX(-5px);}
.ms-card:hover::after{opacity:0.6;transform:translateX(0);}
.ms-card:hover{transform:translateY(-3px);box-shadow:var(--glow);}
.ms-card.sym-card-s:hover{border-color:var(--cyan);box-shadow:var(--glow);}
.ms-card.asym-card-s:hover{border-color:var(--purple);box-shadow:var(--glow-purple);}
.ms-card-icon{font-size:2rem;margin-bottom:0.8rem;display:block;}
.ms-card-name{font-family:'Orbitron',monospace;font-size:0.78rem;font-weight:700;letter-spacing:0.08em;color:var(--white);margin-bottom:0.4rem;}
.ms-card-desc{font-size:0.78rem;color:var(--dim);line-height:1.4;}
.ms-badge{display:inline-block;margin-top:0.6rem;padding:2px 8px;border-radius:2px;font-family:'Share Tech Mono',monospace;font-size:0.58rem;letter-spacing:0.1em;}
.badge-low{background:rgba(255,51,102,0.15);color:var(--red);border:1px solid rgba(255,51,102,0.3);}
.badge-med{background:rgba(255,183,0,0.15);color:var(--amber);border:1px solid rgba(255,183,0,0.3);}
.badge-high{background:rgba(0,255,157,0.15);color:var(--green);border:1px solid rgba(0,255,157,0.3);}
.badge-max{background:rgba(0,229,255,0.15);color:var(--cyan);border:1px solid rgba(0,229,255,0.3);}
.badge-hash{background:rgba(255,183,0,0.15);color:var(--amber);border:1px solid rgba(255,183,0,0.3);}

/* ══════════════════════════════════════════════
   OPERATION PAGE
══════════════════════════════════════════════ */
.page-container{max-width:860px;margin:0 auto;padding:1.5rem 1.5rem 3rem;width:100%;flex:1;}
.back-btn{display:inline-flex;align-items:center;gap:0.5rem;font-family:'Share Tech Mono',monospace;font-size:0.78rem;color:var(--dim);cursor:pointer;letter-spacing:0.12em;border:none;background:none;transition:color 0.2s;margin-bottom:1.8rem;text-transform:uppercase;}
.back-btn:hover{color:var(--cyan);}
.op-header{margin-bottom:2rem;padding-bottom:1rem;border-bottom:1px solid var(--border);}
.op-title{font-family:'Orbitron',monospace;font-size:clamp(1rem,3vw,1.5rem);font-weight:900;color:var(--cyan);letter-spacing:0.1em;}
.op-subtitle{font-size:0.85rem;color:var(--dim);margin-top:0.4rem;line-height:1.5;}
.op-badge-row{display:flex;gap:0.5rem;margin-top:0.8rem;flex-wrap:wrap;}
.info-box{background:rgba(0,229,255,0.04);border:1px solid rgba(0,229,255,0.12);border-radius:4px;padding:1rem 1.2rem;margin-bottom:1.5rem;font-size:0.82rem;color:var(--dim);line-height:1.55;}
.info-box.purple-box{background:rgba(187,134,252,0.04);border-color:rgba(187,134,252,0.12);}
.info-box strong{color:var(--white);}
.section-title{font-family:'Orbitron',monospace;font-size:0.8rem;color:var(--cyan);letter-spacing:0.25em;text-transform:uppercase;margin-bottom:1rem;display:flex;align-items:center;gap:0.6rem;}
.section-title.purple{color:var(--purple);}
.section-title::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,var(--border),transparent);}
.styled-input,.styled-textarea{width:100%;background:rgba(0,15,30,0.8);border:1px solid var(--border);border-radius:3px;color:var(--white);font-family:'Share Tech Mono',monospace;font-size:0.85rem;padding:0.7rem 1rem;transition:border-color 0.2s,box-shadow 0.2s;outline:none;caret-color:var(--cyan);}
.styled-input:focus,.styled-textarea:focus{border-color:var(--cyan2);box-shadow:0 0 10px rgba(0,229,255,0.15);}
.styled-textarea{resize:vertical;min-height:110px;line-height:1.6;}
.key-block{display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem;flex-wrap:wrap;}
.key-label{font-family:'Share Tech Mono',monospace;font-size:0.78rem;color:var(--cyan);letter-spacing:0.12em;white-space:nowrap;min-width:80px;}
.key-input-wrap{flex:1;position:relative;min-width:200px;}
.gen-btn{padding:0.65rem 1.2rem;border:1px solid var(--cyan2);background:transparent;color:var(--cyan);font-family:'Share Tech Mono',monospace;font-size:0.72rem;letter-spacing:0.1em;cursor:pointer;transition:all 0.2s;text-transform:uppercase;border-radius:2px;white-space:nowrap;}
.gen-btn:hover{background:rgba(0,229,255,0.1);}
.action-btn{display:block;width:100%;padding:1rem;background:transparent;border:1px solid var(--cyan);color:var(--cyan);font-family:'Orbitron',monospace;font-size:0.9rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;cursor:pointer;transition:all 0.3s;border-radius:3px;margin-top:1.5rem;position:relative;overflow:hidden;}
.action-btn.purple{border-color:var(--purple);color:var(--purple);}
.action-btn.green{border-color:var(--green);color:var(--green);}
.action-btn.amber{border-color:var(--amber);color:var(--amber);}
.action-btn::before{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(0,229,255,0.12),transparent);transition:left 0.4s;}
.action-btn:hover::before{left:100%;}
.action-btn:hover{background:rgba(0,229,255,0.08);box-shadow:var(--glow);}
.action-btn.purple:hover{background:rgba(187,134,252,0.08);box-shadow:var(--glow-purple);}
.action-btn.green:hover{background:rgba(0,255,157,0.08);box-shadow:var(--glow-green);}

/* Output */
.output-panel{margin-top:2.5rem;border:1px solid var(--border);border-radius:4px;background:rgba(0,10,20,0.7);overflow:hidden;backdrop-filter:blur(6px);display:none;animation:panel-reveal 0.4s ease forwards;}
.output-panel.visible{display:block;}
@keyframes panel-reveal{from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);}}
.output-header{background:rgba(0,229,255,0.08);border-bottom:1px solid var(--border);padding:0.8rem 1.2rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;}
.output-label{font-family:'Orbitron',monospace;font-size:0.72rem;color:var(--cyan);letter-spacing:0.2em;}
.output-meta{font-family:'Share Tech Mono',monospace;font-size:0.7rem;color:var(--dim);letter-spacing:0.1em;}
.output-body{padding:1.5rem;}
.cipher-display{font-family:'Share Tech Mono',monospace;font-size:0.82rem;line-height:1.7;color:var(--green);word-break:break-all;background:rgba(0,255,157,0.03);border:1px solid rgba(0,255,157,0.12);border-radius:3px;padding:1rem;position:relative;min-height:60px;text-shadow:0 0 8px rgba(0,255,157,0.3);}
.cipher-display.purple-out{color:var(--purple);background:rgba(187,134,252,0.03);border-color:rgba(187,134,252,0.12);text-shadow:0 0 8px rgba(187,134,252,0.3);}
.cipher-display.amber-out{color:var(--amber);background:rgba(255,183,0,0.03);border-color:rgba(255,183,0,0.15);text-shadow:0 0 8px rgba(255,183,0,0.3);}
.copy-btn{position:absolute;top:8px;right:8px;background:rgba(0,20,35,0.9);border:1px solid var(--border);color:var(--dim);font-family:'Share Tech Mono',monospace;font-size:0.65rem;padding:3px 8px;cursor:pointer;transition:all 0.2s;letter-spacing:0.1em;}
.copy-btn:hover{color:var(--cyan);border-color:var(--cyan);}
.key-display{margin-top:1.2rem;background:rgba(0,20,35,0.7);border:1px dashed var(--border);border-radius:3px;padding:0.8rem 1rem;font-family:'Share Tech Mono',monospace;font-size:0.78rem;color:var(--amber);word-break:break-all;display:flex;justify-content:space-between;gap:1rem;align-items:flex-start;flex-wrap:wrap;}
.key-info-label{font-family:'Share Tech Mono',monospace;font-size:0.65rem;color:var(--dim);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:0.3rem;}
.security-block{margin-top:1.5rem;border:1px solid var(--border);border-radius:3px;padding:1.2rem;background:rgba(0,10,25,0.5);}
.security-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:0.9rem;}
.security-title{font-family:'Share Tech Mono',monospace;font-size:0.72rem;color:var(--dim);letter-spacing:0.15em;text-transform:uppercase;}
.security-value{font-family:'Orbitron',monospace;font-size:1.4rem;font-weight:900;transition:color 0.3s;}
.meter-track{width:100%;height:8px;background:rgba(255,255,255,0.06);border-radius:4px;overflow:hidden;position:relative;}
.meter-fill{height:100%;border-radius:4px;transition:width 1.2s cubic-bezier(.4,0,.2,1);position:relative;overflow:hidden;}
.meter-fill::after{content:'';position:absolute;top:0;left:-60%;width:60%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.3),transparent);animation:shimmer 2s infinite;}
@keyframes shimmer{to{left:160%;}}
.security-bars{display:flex;gap:3px;margin-top:0.8rem;}
.s-bar{flex:1;height:20px;border-radius:2px;transition:background 0.3s;}
.security-annotations{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:0.6rem;margin-top:1.2rem;}
.annot{font-size:0.73rem;color:var(--dim);line-height:1.4;display:flex;gap:0.4rem;align-items:flex-start;}
.annot-icon{color:var(--cyan);font-size:0.85rem;flex-shrink:0;}

/* Key pair display */
.key-pair-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-top:1rem;}
.key-pair-box{background:rgba(0,15,30,0.8);border:1px solid var(--border);border-radius:3px;padding:1rem;}
.kp-label{font-family:'Share Tech Mono',monospace;font-size:0.65rem;color:var(--dim);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:0.5rem;}
.kp-value{font-family:'Share Tech Mono',monospace;font-size:0.75rem;color:var(--amber);word-break:break-all;line-height:1.5;}
.kp-value.pub{color:var(--cyan);}
@media(max-width:600px){.key-pair-grid{grid-template-columns:1fr;}}

/* DH steps */
.dh-step{background:rgba(0,15,30,0.6);border:1px solid var(--border);border-radius:3px;padding:0.9rem 1rem;margin-bottom:0.8rem;}
.dh-step-label{font-family:'Share Tech Mono',monospace;font-size:0.65rem;color:var(--purple);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:0.4rem;}
.dh-step-val{font-family:'Share Tech Mono',monospace;font-size:0.8rem;color:var(--white);}
.dh-shared{border-color:var(--green);background:rgba(0,255,157,0.04);}
.dh-shared .dh-step-label{color:var(--green);}

/* Hash output */
.hash-display{font-family:'Share Tech Mono',monospace;font-size:0.88rem;color:var(--amber);word-break:break-all;background:rgba(255,183,0,0.03);border:1px solid rgba(255,183,0,0.15);border-radius:3px;padding:1rem;position:relative;text-shadow:0 0 8px rgba(255,183,0,0.3);letter-spacing:0.05em;}

/* noise indicator */
.noise-indicator{display:inline-flex;align-items:center;gap:4px;margin-top:0.5rem;}
.noise-dot{width:6px;height:6px;border-radius:50%;animation:noise-pulse 1.2s ease-in-out infinite;}
.noise-dot:nth-child(2){animation-delay:0.2s;}
.noise-dot:nth-child(3){animation-delay:0.4s;}
@keyframes noise-pulse{0%,100%{opacity:0.3;transform:scale(0.8);}50%{opacity:1;transform:scale(1.2);}}

@media(max-width:700px){.divider-v{display:none;}.home-cards{gap:1.5rem;}.ms-ops{flex-wrap:wrap;}}

/* ══════════════════════════════════════════════
   THREE-DOTS BUTTON
══════════════════════════════════════════════ */
.three-dots-btn{
  position:absolute;top:10px;right:10px;
  width:28px;height:28px;
  background:rgba(0,15,30,0.7);
  border:1px solid var(--border);
  border-radius:50%;
  cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  flex-direction:column;gap:3px;
  z-index:20;
  transition:all 0.2s;
  padding:0;
}
.three-dots-btn:hover{border-color:var(--cyan);background:rgba(0,229,255,0.12);box-shadow:0 0 10px rgba(0,229,255,0.3);}
.three-dots-btn .dot{width:3.5px;height:3.5px;border-radius:50%;background:var(--dim);transition:background 0.2s;}
.three-dots-btn:hover .dot{background:var(--cyan);}

/* ══════════════════════════════════════════════
   ALGORITHM MODAL
══════════════════════════════════════════════ */
.algo-modal-overlay{
  position:fixed;inset:0;z-index:1000;
  background:rgba(2,4,8,0.88);
  backdrop-filter:blur(10px);
  display:flex;align-items:center;justify-content:center;
  opacity:0;pointer-events:none;
  transition:opacity 0.3s ease;
}
.algo-modal-overlay.open{opacity:1;pointer-events:all;}
.algo-modal{
  width:min(780px,96vw);
  max-height:88vh;
  background:linear-gradient(135deg,rgba(0,20,40,0.98),rgba(2,8,20,0.98));
  border:1px solid var(--border);
  border-radius:8px;
  overflow:hidden;
  display:flex;flex-direction:column;
  box-shadow:0 0 60px rgba(0,229,255,0.12),inset 0 0 80px rgba(0,229,255,0.02);
  transform:scale(0.92) translateY(20px);
  transition:transform 0.35s cubic-bezier(.34,1.56,.64,1);
}
.algo-modal-overlay.open .algo-modal{transform:scale(1) translateY(0);}
.algo-modal-head{
  padding:1.2rem 1.5rem;
  background:rgba(0,229,255,0.06);
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
  flex-shrink:0;
}
.algo-modal-head.purple-head{background:rgba(187,134,252,0.06);border-bottom-color:rgba(187,134,252,0.2);}
.algo-modal-title{font-family:'Orbitron',monospace;font-size:0.92rem;font-weight:900;letter-spacing:0.12em;color:var(--cyan);}
.algo-modal-title.purple{color:var(--purple);}
.algo-modal-subtitle{font-family:'Share Tech Mono',monospace;font-size:0.68rem;color:var(--dim);letter-spacing:0.15em;margin-top:0.2rem;}
.algo-modal-close{
  width:32px;height:32px;border-radius:50%;
  background:transparent;border:1px solid var(--border);
  color:var(--dim);font-size:1.1rem;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  transition:all 0.2s;flex-shrink:0;
}
.algo-modal-close:hover{border-color:var(--red);color:var(--red);background:rgba(255,51,102,0.1);}
.algo-modal-body{
  overflow-y:auto;
  padding:1.5rem;
  flex:1;
  scrollbar-width:thin;
  scrollbar-color:var(--border) transparent;
}
.algo-modal-body::-webkit-scrollbar{width:4px;}
.algo-modal-body::-webkit-scrollbar-track{background:transparent;}
.algo-modal-body::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px;}

/* Sections inside modal */
.algo-section{margin-bottom:1.8rem;}
.algo-section-title{
  font-family:'Orbitron',monospace;font-size:0.7rem;
  color:var(--cyan);letter-spacing:0.25em;
  text-transform:uppercase;margin-bottom:0.9rem;
  display:flex;align-items:center;gap:0.6rem;
}
.algo-section-title.purple{color:var(--purple);}
.algo-section-title::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,var(--border),transparent);}
.algo-para{font-size:0.83rem;color:var(--dim);line-height:1.7;margin-bottom:0.8rem;}
.algo-para strong{color:var(--white);}
.algo-para code{font-family:'Share Tech Mono',monospace;font-size:0.78rem;color:var(--cyan);background:rgba(0,229,255,0.07);padding:1px 5px;border-radius:2px;}

/* Architecture flow diagram */
.arch-flow{display:flex;align-items:center;flex-wrap:wrap;gap:0;margin:1rem 0;}
.arch-box{
  background:rgba(0,20,40,0.8);border:1px solid var(--border);
  border-radius:4px;padding:0.55rem 0.9rem;
  font-family:'Share Tech Mono',monospace;font-size:0.7rem;
  color:var(--white);text-align:center;min-width:80px;
  transition:border-color 0.2s;white-space:nowrap;
}
.arch-box.highlight{border-color:var(--cyan);color:var(--cyan);background:rgba(0,229,255,0.08);}
.arch-box.highlight.purple{border-color:var(--purple);color:var(--purple);background:rgba(187,134,252,0.08);}
.arch-box.highlight.green{border-color:var(--green);color:var(--green);background:rgba(0,255,157,0.08);}
.arch-box.highlight.amber{border-color:var(--amber);color:var(--amber);background:rgba(255,183,0,0.08);}
.arch-arrow{color:var(--border);font-size:1.1rem;padding:0 0.3rem;flex-shrink:0;}
.arch-stack{display:flex;flex-direction:column;gap:0.5rem;}
.arch-row{display:flex;align-items:center;flex-wrap:wrap;gap:0;}

/* Specs table */
.specs-table{width:100%;border-collapse:collapse;font-size:0.8rem;margin-top:0.5rem;}
.specs-table th{font-family:'Share Tech Mono',monospace;font-size:0.62rem;color:var(--dim);letter-spacing:0.12em;text-transform:uppercase;padding:0.5rem 0.8rem;border-bottom:1px solid var(--border);text-align:left;}
.specs-table td{padding:0.55rem 0.8rem;border-bottom:1px solid rgba(0,229,255,0.05);color:var(--dim);vertical-align:top;line-height:1.5;}
.specs-table td:first-child{color:var(--white);font-family:'Share Tech Mono',monospace;font-size:0.75rem;white-space:nowrap;}
.specs-table td strong{color:var(--cyan);}
.specs-table td strong.purple{color:var(--purple);}
.specs-table td strong.green{color:var(--green);}
.specs-table td strong.amber{color:var(--amber);}
.specs-table td strong.red{color:var(--red);}
.specs-table tr:last-child td{border-bottom:none;}

/* Rounds visual */
.rounds-visual{display:flex;gap:4px;flex-wrap:wrap;margin:0.8rem 0;}
.round-pill{font-family:'Share Tech Mono',monospace;font-size:0.58rem;padding:3px 7px;border-radius:12px;background:rgba(0,229,255,0.08);border:1px solid rgba(0,229,255,0.2);color:var(--cyan);letter-spacing:0.05em;}
.round-pill.purple{background:rgba(187,134,252,0.08);border-color:rgba(187,134,252,0.2);color:var(--purple);}
.round-pill.amber{background:rgba(255,183,0,0.08);border-color:rgba(255,183,0,0.2);color:var(--amber);}

@media(max-width:600px){.arch-flow{gap:4px;}.arch-box{font-size:0.62rem;padding:0.4rem 0.6rem;min-width:60px;}}
</style>
</head>
<body>

<canvas id="bg-canvas"></canvas>
<div class="grid-overlay"></div>
<div class="scanlines"></div>
<div class="corner-deco tl"></div>
<div class="corner-deco tr"></div>
<div class="corner-deco bl"></div>
<div class="corner-deco br"></div>

<!-- ══════════════════ LOGIN PAGE ══════════════════ -->
<div id="login" class="page active">
  <div class="login-wrapper">
    <div class="login-header">
      <span class="login-icon">🙈</span>
      <div class="logo glitch-text">HIDE <span>&</span> SEEK</div>
      <div class="tagline">Cryptographic Playground — v2.0</div>
    </div>
    <div class="login-box">
      <div class="login-title">⟨ Access Terminal ⟩</div>
      <div class="form-group">
        <label class="form-label" for="l-user">Username</label>
        <input class="form-input" type="text" id="l-user" placeholder="Enter username..." autocomplete="off"/>
      </div>
      <div class="form-group">
        <label class="form-label" for="l-pass">Password</label>
        <input class="form-input" type="password" id="l-pass" placeholder="Enter password..."/>
      </div>
      <button class="login-btn" onclick="doLogin()">⟶ INITIATE SESSION</button>
      <div class="login-err" id="login-err">⚠ Invalid credentials. Try: admin / 1234</div>
      <div class="login-hint">Hint: username = admin &nbsp;|&nbsp; password = 1234</div>
    </div>
  </div>
</div>

<!-- ══════════════════ HOME PAGE ══════════════════ -->
<div id="home" class="page">
  <header>
    <div class="logo glitch-text">HIDE <span>&</span> SEEK</div>
    <div class="tagline">Choose Your Cryptographic Domain</div>
    <div class="header-line"></div>
    <button class="logout-btn" onclick="doLogout()">⏻ LOGOUT</button>
  </header>
  <div class="home-cards">
    <div class="home-card sym-card" onclick="goMethodSelect('symmetric')">
      <div class="card-number">1</div>
      <div class="card-icon">🔑</div>
      <div class="card-title">SYMMETRIC KEY CRYPTOGRAPHY</div>
      <div class="card-desc">Single shared key for both encryption and decryption. Blazing fast for large data.</div>
      <div class="card-methods">
        <span class="card-method-tag sym-tag">AES</span>
        <span class="card-method-tag sym-tag">DES</span>
        <span class="card-method-tag sym-tag">Blowfish</span>
        <span class="card-method-tag sym-tag">JCA</span>
        <span class="card-method-tag sym-tag">SHA-1</span>
      </div>
      <button class="card-btn">ENTER →</button>
    </div>
    <div class="divider-v"></div>
    <div class="home-card asym-card" onclick="goMethodSelect('asymmetric')">
      <div class="card-number">2</div>
      <div class="card-icon">🗝️</div>
      <div class="card-title">ASYMMETRIC KEY CRYPTOGRAPHY</div>
      <div class="card-desc">Public/private key pairs. Encrypt with one, decrypt with the other. Secure key exchange.</div>
      <div class="card-methods">
        <span class="card-method-tag asym-tag">RSA</span>
        <span class="card-method-tag asym-tag">Diffie-Hellman</span>
      </div>
      <button class="card-btn">ENTER →</button>
    </div>
  </div>
</div>

<!-- ══════════════════ METHOD SELECT PAGE ══════════════════ -->
<div id="method-select" class="page">
  <header>
    <div class="logo glitch-text">HIDE <span>&</span> SEEK</div>
    <div class="tagline" id="ms-tagline">Select Method &amp; Operation</div>
    <div class="header-line"></div>
  </header>
  <div class="method-select-header">
    <div class="ms-ops" id="ms-ops-row">
      <!-- populated by JS -->
    </div>
  </div>
  <div class="method-select-grid" id="ms-grid">
    <!-- populated by JS -->
  </div>
</div>

<!-- ══════════════════ OPERATION PAGE ══════════════════ -->
<div id="operation" class="page">
  <header>
    <div class="logo glitch-text">HIDE <span>&</span> SEEK</div>
    <div class="tagline" id="op-mode-label">Encryption</div>
    <div class="header-line"></div>
  </header>
  <div class="page-container">
    <button class="back-btn" onclick="goTo('method-select')">← BACK TO METHODS</button>
    <div class="op-header">
      <div class="op-title" id="op-title">AES ENCRYPTION</div>
      <div class="op-subtitle" id="op-subtitle"></div>
      <div class="op-badge-row" id="op-badge-row"></div>
    </div>
    <div class="info-box" id="op-info-box"></div>
    <div id="op-body"><!-- dynamic --></div>
  </div>
</div>

<!-- ══════════════════ ALGORITHM MODAL ══════════════════ -->
<div class="algo-modal-overlay" id="algo-modal-overlay" onclick="closeAlgoModal(event)">
  <div class="algo-modal" id="algo-modal">
    <div class="algo-modal-head" id="algo-modal-head">
      <div>
        <div class="algo-modal-title" id="algo-modal-title">ALGORITHM INFO</div>
        <div class="algo-modal-subtitle" id="algo-modal-subtitle"></div>
      </div>
      <button class="algo-modal-close" onclick="closeAlgoModal(null)">✕</button>
    </div>
    <div class="algo-modal-body" id="algo-modal-body"></div>
  </div>
</div>

<script>
// ═══════════════════════════════════════════════════════
//                    LOGIN LOGIC
// ═══════════════════════════════════════════════════════
let loggedIn = false;
function doLogin() {
  const u = document.getElementById('l-user').value.trim();
  const p = document.getElementById('l-pass').value.trim();
  const err = document.getElementById('login-err');
  if (u === 'admin' && p === '1234') {
    loggedIn = true; err.style.display = 'none';
    goTo('home');
  } else {
    err.style.display = 'block';
    const box = document.querySelector('.login-box');
    box.style.animation = 'none';
    box.style.borderColor = 'var(--red)';
    box.style.boxShadow = '0 0 20px rgba(255,51,102,0.3)';
    setTimeout(() => { box.style.borderColor = ''; box.style.boxShadow = ''; }, 800);
  }
}
document.getElementById('l-pass').addEventListener('keydown', e => { if (e.key === 'Enter') doLogin(); });
document.getElementById('l-user').addEventListener('keydown', e => { if (e.key === 'Enter') document.getElementById('l-pass').focus(); });

function doLogout() { loggedIn = false; goTo('login'); document.getElementById('l-user').value=''; document.getElementById('l-pass').value=''; }

// ═══════════════════════════════════════════════════════
//                    PAGE NAVIGATION
// ═══════════════════════════════════════════════════════
function goTo(page) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById(page).classList.add('active');
  window.scrollTo(0,0);
}

// ═══════════════════════════════════════════════════════
//                  METHOD DEFINITIONS
// ═══════════════════════════════════════════════════════
const SYMMETRIC_METHODS = [
  {
    id:'aes', name:'AES', fullName:'Advanced Encryption Standard',
    icon:'🛡️', badge:'badge-max', badgeText:'MILITARY-GRADE',
    type:'sym', ops:['encrypt','decrypt'],
    desc:'128/256-bit block cipher. Used by governments worldwide.',
    info:'AES operates on 128-bit blocks in 10/12/14 rounds of SubBytes, ShiftRows, MixColumns, and AddRoundKey transformations. It is the <strong>current global standard</strong> for symmetric encryption.',
    security:95,
    annotations:['✦ Block cipher — 128-bit blocks','✦ 10 rounds (AES-128)','✦ Brute-force infeasible','✦ Used in TLS, WPA2, banking']
  },
  {
    id:'des', name:'DES', fullName:'Data Encryption Standard',
    icon:'🔐', badge:'badge-low', badgeText:'LEGACY / WEAK',
    type:'sym', ops:['encrypt','decrypt'],
    desc:'56-bit key Feistel cipher. Historical standard, now deprecated.',
    info:'DES uses a <strong>56-bit key</strong> and 16 rounds of Feistel network. Key size is too small for modern security — cracked in 22 hours by distributed computing in 1999. Use <strong>3DES or AES</strong> instead.',
    security:15,
    annotations:['⚠ 56-bit key — vulnerable','⚠ Cracked in 1999 by EFF','⚠ Deprecated by NIST','✦ Historical — still taught']
  },
  {
    id:'blowfish', name:'Blowfish', fullName:'Blowfish Cipher',
    icon:'🐡', badge:'badge-high', badgeText:'STRONG',
    type:'sym', ops:['encrypt','decrypt'],
    desc:'64-bit block, variable key (32–448 bits). Fast & royalty-free.',
    info:'Designed by Bruce Schneier in 1993. Blowfish uses a <strong>Feistel structure with 16 rounds</strong> and a variable-length key from 32 to 448 bits. It is unpatented and freely available — popular in password hashing (bcrypt).',
    security:78,
    annotations:['✦ Variable key 32–448 bits','✦ 16 rounds Feistel','✦ No license fees','✦ Used in bcrypt']
  },
  {
    id:'jca', name:'JCA', fullName:'Java Cryptography Architecture',
    icon:'☕', badge:'badge-med', badgeText:'FRAMEWORK',
    type:'sym', ops:['encrypt','decrypt'],
    desc:'Java\'s unified API framework for cryptographic operations.',
    info:'JCA is <strong>not an algorithm itself</strong> but a provider-based cryptographic framework in Java. It unifies access to algorithms like AES, RSA, SHA via <code>Cipher.getInstance("AES/CBC/PKCS5Padding")</code>. Simulated here with AES-CBC mode.',
    security:82,
    annotations:['✦ Provider-based architecture','✦ Pluggable algorithm backends','✦ CBC mode with IV','✦ PKCS5 padding']
  },
  {
    id:'sha1', name:'SHA-1', fullName:'Secure Hash Algorithm 1',
    icon:'#️⃣', badge:'badge-med', badgeText:'HASH ONLY',
    type:'sym', ops:['hash'],
    desc:'160-bit cryptographic hash function. One-way — not encryption.',
    info:'SHA-1 produces a <strong>160-bit (40 hex char) digest</strong>. It is a one-way function — you cannot reverse it. Collision attacks were demonstrated in 2017 (SHAttered). Used for checksums and legacy digital signatures.',
    security:45,
    annotations:['⚠ Collision attacks found 2017','✦ 160-bit output (40 hex chars)','✦ One-way — no decryption','✦ Still used for checksums']
  }
];
const ASYMMETRIC_METHODS = [
  {
    id:'rsa', name:'RSA', fullName:'Rivest–Shamir–Adleman',
    icon:'🔏', badge:'badge-max', badgeText:'GOLD STANDARD',
    type:'asym', ops:['encrypt','decrypt'],
    desc:'Public/private key encryption based on prime factorisation.',
    info:'RSA security relies on the computational difficulty of <strong>factoring large integers</strong>. A public key (n, e) encrypts; a private key (n, d) decrypts. Key sizes of 2048+ bits are recommended for modern security.',
    security:92,
    annotations:['✦ Based on prime factorisation','✦ Public & private key pair','✦ 2048-bit recommended','✦ Used in HTTPS, SSH, PGP']
  },
  {
    id:'dh', name:'Diffie-Hellman', fullName:'Diffie-Hellman Key Exchange',
    icon:'🤝', badge:'badge-high', badgeText:'KEY EXCHANGE',
    type:'asym', ops:['keygen'],
    desc:'Secure key exchange over public channel. No prior shared secret.',
    info:'Two parties each generate a private value and compute a public value using modular exponentiation. They exchange public values and compute the same <strong>shared secret</strong> — without ever transmitting it directly.',
    security:88,
    annotations:['✦ No shared secret transmitted','✦ Discrete log problem','✦ Basis for TLS, Signal, PGP','✦ Forward secrecy when ephemeral']
  }
];

let currentCategory = 'symmetric';
let currentOp = 'encrypt';
let currentMethod = null;

function goMethodSelect(category) {
  currentCategory = category;
  document.getElementById('ms-tagline').textContent =
    category === 'symmetric' ? 'Symmetric Key Cryptography — Choose Method' : 'Asymmetric Key Cryptography — Choose Method';
  const methods = category === 'symmetric' ? SYMMETRIC_METHODS : ASYMMETRIC_METHODS;
  // Build ops
  const ops = [...new Set(methods.flatMap(m => m.ops))];
  currentOp = ops[0];
  const opsRow = document.getElementById('ms-ops-row');
  opsRow.innerHTML = ops.map(op => {
    const lbl = op === 'encrypt' ? '⚡ ENCRYPT' : op === 'decrypt' ? '🔓 DECRYPT' : op === 'hash' ? '# HASH' : '🔑 KEY EXCHANGE';
    const cls = op === currentOp ? (op === 'hash' ? 'ms-op-btn active-hash' : op === 'decrypt' ? 'ms-op-btn active-dec' : 'ms-op-btn active-enc') : 'ms-op-btn';
    return `<button class="${cls}" onclick="setOp('${op}')">${lbl}</button>`;
  }).join('');
  renderMethodGrid(category, currentOp);
  goTo('method-select');
}

function setOp(op) {
  currentOp = op;
  document.querySelectorAll('.ms-op-btn').forEach(b => b.className = 'ms-op-btn');
  event.target.className = 'ms-op-btn ' + (op === 'hash' ? 'active-hash' : op === 'decrypt' ? 'active-dec' : 'active-enc');
  renderMethodGrid(currentCategory, op);
}

function renderMethodGrid(category, op) {
  const methods = (category === 'symmetric' ? SYMMETRIC_METHODS : ASYMMETRIC_METHODS).filter(m => m.ops.includes(op));
  const grid = document.getElementById('ms-grid');
  const cardClass = category === 'symmetric' ? 'sym-card-s' : 'asym-card-s';
  grid.innerHTML = methods.map(m => `
    <div class="ms-card ${cardClass}" onclick="goOperation('${m.id}')">
      <button class="three-dots-btn" onclick="event.stopPropagation();openAlgoModal('${m.id}')" title="View Algorithm & Architecture">
        <span class="dot"></span><span class="dot"></span><span class="dot"></span>
      </button>
      <span class="ms-card-icon">${m.icon}</span>
      <div class="ms-card-name">${m.name}</div>
      <div class="ms-card-desc">${m.desc}</div>
      <span class="ms-badge ${m.badge}">${m.badgeText}</span>
    </div>
  `).join('');
}

// ═══════════════════════════════════════════════════════
//               OPERATION PAGE BUILDER
// ═══════════════════════════════════════════════════════
function goOperation(methodId) {
  const allMethods = [...SYMMETRIC_METHODS, ...ASYMMETRIC_METHODS];
