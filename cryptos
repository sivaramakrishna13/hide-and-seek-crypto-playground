// ═══════════════════════════════════════════════════════
//               CRYPTO IMPLEMENTATIONS
// ═══════════════════════════════════════════════════════

// ── Helper: simple key-based XOR stream ──
function xorStream(text, key) {
  let out = '';
  for (let i = 0; i < text.length; i++) {
    out += String.fromCharCode(text.charCodeAt(i) ^ key.charCodeAt(i % key.length));
  }
  return out;
}
function toHex(str) { return Array.from(str).map(c => c.charCodeAt(0).toString(16).padStart(2,'0')).join(''); }
function fromHex(hex) {
  let str = '';
  for (let i = 0; i < hex.length; i += 2) str += String.fromCharCode(parseInt(hex.substr(i,2),16));
  return str;
}

// ── AES-like simulation (XOR + substitution + rounds) ──
const S_BOX = Array.from({length:256},(_,i) => ((i * 167 + 83) % 256));
const S_BOX_INV = (() => { const t = new Array(256); S_BOX.forEach((v,k) => t[v]=k); return t; })();
function aesSimEncrypt(text, key) {
  if (!key) return '[No key provided]';
  let bytes = Array.from(text).map(c => c.charCodeAt(0));
  const kBytes = Array.from(key).map(c => c.charCodeAt(0));
  // 3 rounds: SubBytes + AddRoundKey
  for (let r = 0; r < 3; r++) {
    bytes = bytes.map(b => S_BOX[b]);
    bytes = bytes.map((b,i) => b ^ kBytes[(i + r) % kBytes.length]);
  }
  return toHex(String.fromCharCode(...bytes));
}
function aesSimDecrypt(hex, key) {
  if (!key) return '[No key provided]';
  try {
    let bytes = Array.from(fromHex(hex)).map(c => c.charCodeAt(0));
    const kBytes = Array.from(key).map(c => c.charCodeAt(0));
    for (let r = 2; r >= 0; r--) {
      bytes = bytes.map((b,i) => b ^ kBytes[(i + r) % kBytes.length]);
      bytes = bytes.map(b => S_BOX_INV[b]);
    }
    return String.fromCharCode(...bytes);
  } catch(e) { return '[Decryption failed — wrong key or malformed input]'; }
}

// ── DES simulation (simplified Feistel, 16 rounds) ──
function desEncrypt(text, key) {
  if (!key) return '[No key provided]';
  const kBytes = Array.from(key.padEnd(8,'0').slice(0,8)).map(c => c.charCodeAt(0));
  let bytes = Array.from(text).map(c => c.charCodeAt(0));
  // 16 rounds of simple Feistel
  for (let r = 0; r < 16; r++) {
    bytes = bytes.map((b,i) => {
      const k = kBytes[(i + r * 3) % 8];
      return ((b ^ k) + r * 7) & 0xFF;
    });
  }
  return toHex(String.fromCharCode(...bytes));
}
function desDecrypt(hex, key) {
  if (!key) return '[No key provided]';
  try {
    const kBytes = Array.from(key.padEnd(8,'0').slice(0,8)).map(c => c.charCodeAt(0));
    let bytes = Array.from(fromHex(hex)).map(c => c.charCodeAt(0));
    for (let r = 15; r >= 0; r--) {
      bytes = bytes.map((b,i) => {
        const k = kBytes[(i + r * 3) % 8];
        return ((b - r * 7 + 256) & 0xFF) ^ k;
      });
    }
    return String.fromCharCode(...bytes);
  } catch(e) { return '[Decryption failed]'; }
}

// ── Blowfish simulation (variable key Feistel) ──
function blowfishEncrypt(text, key) {
  if (!key) return '[No key provided]';
  const kLen = key.length;
  let bytes = Array.from(text).map(c => c.charCodeAt(0));
  for (let r = 0; r < 16; r++) {
    bytes = bytes.map((b,i) => {
      const k = key.charCodeAt((i * 3 + r * 7) % kLen);
      return (b ^ k ^ ((r * 31 + i * 17) & 0xFF)) & 0xFF;
    });
  }
  return toHex(String.fromCharCode(...bytes));
}
function blowfishDecrypt(hex, key) {
  if (!key) return '[No key provided]';
  try {
    const kLen = key.length;
    let bytes = Array.from(fromHex(hex)).map(c => c.charCodeAt(0));
    for (let r = 15; r >= 0; r--) {
      bytes = bytes.map((b,i) => {
        const k = key.charCodeAt((i * 3 + r * 7) % kLen);
        return (b ^ k ^ ((r * 31 + i * 17) & 0xFF)) & 0xFF;
      });
    }
    return String.fromCharCode(...bytes);
  } catch(e) { return '[Decryption failed]'; }
}

// ── JCA simulation (AES-CBC style with IV) ──
function jcaEncrypt(text, key) {
  if (!key) return '[No key provided]';
  // Generate pseudo-IV from key
  const iv = Array.from(key.padEnd(8,'0')).map(c => (c.charCodeAt(0) * 37) & 0xFF);
  let bytes = Array.from(text).map(c => c.charCodeAt(0));
  const kBytes = Array.from(key).map(c => c.charCodeAt(0));
  let prev = iv;
  let out = [];
  // CBC-like: XOR with previous block, then encrypt
  for (let i = 0; i < bytes.length; i++) {
    const xored = bytes[i] ^ prev[i % 8];
    const enc = (xored ^ kBytes[i % kBytes.length] ^ (i * 13)) & 0xFF;
    out.push(enc);
    prev[i % 8] = enc;
  }
  // Prepend IV as hex
  const ivHex = iv.map(b => b.toString(16).padStart(2,'0')).join('');
  return 'JCA:' + ivHex + ':' + toHex(String.fromCharCode(...out));
}
function jcaDecrypt(cipher, key) {
  if (!key) return '[No key provided]';
  try {
    const parts = cipher.split(':');
    if (parts[0] !== 'JCA') return '[Invalid JCA format]';
    const iv = parts[1].match(/.{2}/g).map(h => parseInt(h,16));
    const hex = parts[2];
    const kBytes = Array.from(key).map(c => c.charCodeAt(0));
    let bytes = Array.from(fromHex(hex)).map(c => c.charCodeAt(0));
    let prev = [...iv];
    let out = [];
    for (let i = 0; i < bytes.length; i++) {
      const dec = (bytes[i] ^ kBytes[i % kBytes.length] ^ (i * 13)) & 0xFF;
      out.push(dec ^ prev[i % 8]);
      prev[i % 8] = bytes[i];
    }
    return String.fromCharCode(...out);
  } catch(e) { return '[Decryption failed]'; }
}

// ── SHA-1 pure JS implementation ──
function sha1(msg) {
  function rotl(n,s){return (n<<s)|(n>>>(32-s));}
  function tohex(n){return ('0000000'+n.toString(16)).slice(-8);}
  const utf8 = unescape(encodeURIComponent(msg));
  const bytes = Array.from(utf8).map(c => c.charCodeAt(0));
  const bitLen = bytes.length * 8;
  bytes.push(0x80);
  while ((bytes.length % 64) !== 56) bytes.push(0);
  for (let i = 7; i >= 0; i--) bytes.push((bitLen / Math.pow(2, i*8)) & 0xFF);
  let h0=0x67452301,h1=0xEFCDAB89,h2=0x98BADCFE,h3=0x10325476,h4=0xC3D2E1F0;
  for (let i = 0; i < bytes.length; i += 64) {
    const w = [];
    for (let j = 0; j < 16; j++) w[j] = (bytes[i+j*4]<<24)|(bytes[i+j*4+1]<<16)|(bytes[i+j*4+2]<<8)|bytes[i+j*4+3];
    for (let j = 16; j < 80; j++) w[j] = rotl(w[j-3]^w[j-8]^w[j-14]^w[j-16],1);
    let a=h0,b=h1,c=h2,d=h3,e=h4;
    for (let j = 0; j < 80; j++) {
      let f,k;
      if(j<20){f=(b&c)|((~b)&d);k=0x5A827999;}
      else if(j<40){f=b^c^d;k=0x6ED9EBA1;}
      else if(j<60){f=(b&c)|(b&d)|(c&d);k=0x8F1BBCDC;}
      else{f=b^c^d;k=0xCA62C1D6;}
      const tmp=(rotl(a,5)+f+e+k+w[j])>>>0;
      e=d;d=c;c=rotl(b,30);b=a;a=tmp;
    }
    h0=(h0+a)>>>0;h1=(h1+b)>>>0;h2=(h2+c)>>>0;h3=(h3+d)>>>0;h4=(h4+e)>>>0;
  }
  return tohex(h0)+tohex(h1)+tohex(h2)+tohex(h3)+tohex(h4);
}

// ── RSA simulation ──
function modPow(base, exp, mod) {
  let result = 1n;
  base = base % mod;
  while (exp > 0n) {
    if (exp % 2n === 1n) result = result * base % mod;
    exp = exp / 2n;
    base = base * base % mod;
  }
  return result;
}
const RSA_PARAMS = { p:61n, q:53n, e:17n };
function rsaSetup() {
  const {p,q,e} = RSA_PARAMS;
  const n = p*q;
  const phi = (p-1n)*(q-1n);
  // d = modular inverse of e mod phi
  let [old_r,r] = [phi, e], [old_s,s] = [0n, 1n];
  while (r !== 0n) {
    const q2 = old_r / r;
    [old_r,r] = [r, old_r - q2*r];
    [old_s,s] = [s, old_s - q2*s];
  }
  const d = ((old_s % phi) + phi) % phi;
  return { n, e, d };
}
function rsaEncrypt(text, _key) {
  const {n, e} = rsaSetup();
  const nums = Array.from(text).map(c => modPow(BigInt(c.charCodeAt(0)), e, n));
  return nums.join(',') + `||RSA(n=${n},e=${e})`;
}
function rsaDecrypt(cipher, _key) {
  try {
    const [data] = cipher.split('||');
    const {n, d} = rsaSetup();
    return data.split(',').map(x => String.fromCharCode(Number(modPow(BigInt(x.trim()), d, n)))).join('');
  } catch(e) { return '[RSA Decryption failed — ensure you paste the full RSA output]'; }
}

// ── Diffie-Hellman ──
function dhExchange() {
  const p = BigInt(document.getElementById('dh-p').value || 23);
  const g = BigInt(document.getElementById('dh-g').value || 5);
  const a = BigInt(document.getElementById('dh-a').value || 6);
  const b = BigInt(document.getElementById('dh-b').value || 15);
  const A = modPow(g, a, p); // Alice public
  const B = modPow(g, b, p); // Bob public
  const sA = modPow(B, a, p); // Alice shared
  const sB = modPow(A, b, p); // Bob shared
  return { p, g, a, b, A, B, sA, sB };
}

