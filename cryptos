  const k = document.getElementById('enc-key');
  if (k) k.value = words[Math.floor(Math.random()*words.length)] + (Math.floor(Math.random()*900)+100);
}

function doEncrypt() {
  const m = currentMethod;
  const text = document.getElementById('plain-text').value.trim();
  const key = document.getElementById('enc-key').value.trim();
  if (!text) { flashError('Enter a message to encrypt!'); return; }
  const btn = document.querySelector('#operation .action-btn');
  const orig = btn.textContent;
  btn.textContent = '⚡ ENCRYPTING...'; btn.disabled = true;
  setTimeout(() => {
    let cipher = '';
    if (m.id === 'aes') cipher = aesSimEncrypt(text, key);
    else if (m.id === 'des') cipher = desEncrypt(text, key);
    else if (m.id === 'blowfish') cipher = blowfishEncrypt(text, key);
    else if (m.id === 'jca') cipher = jcaEncrypt(text, key);
    else if (m.id === 'rsa') cipher = rsaEncrypt(text, key);
    document.getElementById('cipher-text-val').querySelector('span').textContent = cipher;
    document.getElementById('used-key-display').textContent = key || '(none)';
    document.getElementById('enc-meta').textContent = `METHOD: ${m.name} | ${new Date().toLocaleTimeString()}`;
    animateSecurity(m);
    const panel = document.getElementById('enc-output');
    panel.classList.add('visible');
    setTimeout(() => panel.scrollIntoView({behavior:'smooth',block:'start'}), 100);
    btn.textContent = orig; btn.disabled = false;
  }, 700);
}

function doDecrypt() {
  const m = currentMethod;
  const cipher = document.getElementById('cipher-input').value.trim();
  const key = document.getElementById('dec-key').value.trim();
  if (!cipher) { flashError('Enter ciphertext to decrypt!'); return; }
  const btn = document.querySelector('#operation .action-btn');
  const orig = btn.textContent;
  btn.textContent = '🔓 DECRYPTING...'; btn.disabled = true;
  setTimeout(() => {
    let plain = '';
    if (m.id === 'aes') plain = aesSimDecrypt(cipher, key);
    else if (m.id === 'des') plain = desDecrypt(cipher, key);
    else if (m.id === 'blowfish') plain = blowfishDecrypt(cipher, key);
    else if (m.id === 'jca') plain = jcaDecrypt(cipher, key);
    else if (m.id === 'rsa') plain = rsaDecrypt(cipher, key);
    document.getElementById('dec-result-val').querySelector('span').textContent = plain;
    document.getElementById('dec-meta').textContent = `METHOD: ${m.name}`;
    const panel = document.getElementById('dec-output');
    panel.classList.add('visible');
    setTimeout(() => panel.scrollIntoView({behavior:'smooth',block:'start'}), 100);
    btn.textContent = orig; btn.disabled = false;
  }, 600);
}

function doHash() {
  const text = document.getElementById('hash-input').value.trim();
