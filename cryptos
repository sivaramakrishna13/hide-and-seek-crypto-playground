  const panel = document.getElementById('dh-output');
  panel.classList.add('visible');
  setTimeout(() => panel.scrollIntoView({behavior:'smooth',block:'start'}), 100);
}

function animateSecurity(method) {
  const pct = method.security;
  let color, gradient;
  if (pct<=20){color='var(--red)';gradient='linear-gradient(90deg,#ff1a40,#ff3366)';}
  else if (pct<=45){color='var(--amber)';gradient='linear-gradient(90deg,#ff6600,#ffb700)';}
  else if (pct<=70){color='#88aaff';gradient='linear-gradient(90deg,#4466ff,#88aaff)';}
  else{color='var(--green)';gradient='linear-gradient(90deg,#00cc77,#00ff9d)';}
  const secVal = document.getElementById('sec-percent');
  const secMeter = document.getElementById('sec-meter');
  secVal.style.color = color; secMeter.style.background = gradient;
  let current = 0;
  const interval = setInterval(() => {
    current = Math.min(current + Math.ceil(pct/30), pct);
    secVal.textContent = current + '%'; secMeter.style.width = current + '%';
    if (current >= pct) clearInterval(interval);
  }, 30);
  const bars = document.getElementById('sec-bars');
  const barCount = 20, filledBars = Math.round((pct/100)*barCount);
  bars.innerHTML = Array.from({length:barCount},(_,i) => {
    const filled = i < filledBars, delay = i * 40;
    return `<div class="s-bar" style="background:${filled?color:'rgba(255,255,255,0.05)'};opacity:${filled?1:0.3};transition:background 0.3s ${delay}ms"></div>`;
  }).join('');
  document.getElementById('sec-annotations').innerHTML = method.annotations.map(a =>
    `<div class="annot"><span class="annot-icon">${a[0]}</span><span>${a.slice(1).trim()}</span></div>`
  ).join('');
}

function copyText(id) {
  const el = document.getElementById(id);
  const text = el.querySelector('span')?.textContent || el.textContent;
  navigator.clipboard.writeText(text).then(() => {
    const btn = el.querySelector('.copy-btn');
    if (btn) { btn.textContent = 'COPIED!'; setTimeout(() => btn.textContent = 'COPY', 1500); }
  });
}

function flashError(msg) {
  const el = document.createElement('div');
  el.style.cssText = `position:fixed;top:20px;left:50%;transform:translateX(-50%);background:rgba(255,30,60,0.15);border:1px solid var(--red);color:var(--red);padding:0.7rem 1.5rem;font-family:'Share Tech Mono',monospace;font-size:0.8rem;letter-spacing:0.1em;z-index:1000;border-radius:3px;box-shadow:0 0 20px rgba(255,30,60,0.3);`;
  el.textContent = '⚠ ' + msg;
  document.body.appendChild(el);
  setTimeout(() => el.remove(), 2500);
}

