      <div class="dh-step-val">s = ${r.B}<sup>${r.a}</sup> mod ${r.p} = ${r.sA}</div>
    </div>
    <div class="dh-step">
      <div class="dh-step-label">Bob computes shared secret: s = A<sup>b</sup> mod p</div>
      <div class="dh-step-val">s = ${r.A}<sup>${r.b}</sup> mod ${r.p} = ${r.sB}</div>
    </div>
    <div class="dh-step dh-shared">
      <div class="dh-step-label">✅ Shared Secret (both computed independently)</div>
      <div class="dh-step-val" style="font-size:1.5rem;color:var(--green);font-weight:bold">${r.sA}</div>
