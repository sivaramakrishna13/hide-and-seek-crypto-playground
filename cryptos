  document.getElementById('op-subtitle').textContent = `${m.fullName} · ${m.badgeText}`;
  document.getElementById('op-badge-row').innerHTML = `<span class="ms-badge ${m.badge}">${m.badgeText}</span>`;
  document.getElementById('op-info-box').className = 'info-box' + (isSym ? '' : ' purple-box');
  document.getElementById('op-info-box').innerHTML = m.info;

  let body = '';
  if (op === 'encrypt') body = buildEncryptUI(m, isSym);
  else if (op === 'decrypt') body = buildDecryptUI(m, isSym);
  else if (op === 'hash') body = buildHashUI(m);
  else if (op === 'keygen') body = buildDHUI(m);

  document.getElementById('op-body').innerHTML = body;
  goTo('operation');
}

