function openAlgoModal(methodId) {
  const data = ALGO_DATA[methodId];
  if (!data) return;
  const isPurple = data.color === 'purple';
  const overlay = document.getElementById('algo-modal-overlay');
  const head = document.getElementById('algo-modal-head');
  const title = document.getElementById('algo-modal-title');
  const subtitle = document.getElementById('algo-modal-subtitle');
  const body = document.getElementById('algo-modal-body');

  head.className = 'algo-modal-head' + (isPurple ? ' purple-head' : '');
  title.className = 'algo-modal-title' + (isPurple ? ' purple' : '');
  title.textContent = data.title;
  subtitle.textContent = data.subtitle;
  body.innerHTML = data.algorithm;
  overlay.classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeAlgoModal(event) {
  if (event && event.target !== document.getElementById('algo-modal-overlay')) return;
  document.getElementById('algo-modal-overlay').classList.remove('open');
  document.body.style.overflow = '';
}

document.addEventListener('keydown', e => { if (e.key === 'Escape') closeAlgoModal(null); });

// ═══════════════════════════════════════════════════════
//                  MATRIX RAIN CANVAS
// ═══════════════════════════════════════════════════════
const canvas = document.getElementById('bg-canvas');
const ctx = canvas.getContext('2d');
let W, H, drops;
const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789@#$%^&*()アイウエオカキクケコ';
function initCanvas(){W=canvas.width=window.innerWidth;H=canvas.height=window.innerHeight;const cols=Math.floor(W/16);drops=Array(cols).fill(1);}
function drawMatrix(){
  ctx.fillStyle='rgba(2,4,8,0.06)';ctx.fillRect(0,0,W,H);ctx.font='12px Share Tech Mono';
  drops.forEach((y,i)=>{
    const c=chars[Math.floor(Math.random()*chars.length)];
    const bright=Math.random()>0.95;
    ctx.fillStyle=bright?'rgba(0,229,255,0.9)':`rgba(0,${Math.floor(Math.random()*100+100)},${Math.floor(Math.random()*50+180)},0.6)`;
    ctx.fillText(c,i*16,y*16);
    if(y*16>H&&Math.random()>0.975)drops[i]=0;
    drops[i]++;
  });
}
initCanvas();
window.addEventListener('resize',initCanvas);
setInterval(drawMatrix,50);
</script>
